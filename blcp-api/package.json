{
   "name": "blcp-api",
   "version": "1.0.0",
   "main": "index.js",
   "license": "MIT",
   "scripts": {
      "dev": "nodemon src/index.ts",
      "typeorm": "typeorm-ts-node-commonjs",
      "build": "tsc -p .",
      "start": "node dist/index.js",
      "setup": "npm run migration:run && npm run seeders:run",
      "test": "NODE_ENV=test bash -c 'yarn seeders:run && jest --coverage'",
      "migration:create": "./scripts/migration.sh",
      "migration:run": "npm run typeorm -- migration:run -d src/database/config.ts",
      "migration:revert": "npm run typeorm -- migration:revert -d src/database/config.ts",
      "migration:show": "npm run typeorm -- migration:show -d src/database/config.ts",
      "seeders:run": "ts-node src/database/seeders/index.ts"
   },
   "dependencies": {
      "bcryptjs": "^3.0.3",
      "dotenv": "17.4.2",
      "express": "5.2.1",
      "jsonwebtoken": "^9.0.3",
      "pg": "8.20.0",
      "redis": "^5.12.1",
      "reflect-metadata": "0.2.2",
      "typeorm": "0.3.29",
      "zod": "^4.4.3"
   },
   "devDependencies": {
      "@eslint/js": "10.0.1",
      "@jest/globals": "^30.4.1",
      "@types/express": "5.0.6",
      "@types/jest": "^30.0.0",
      "@types/jsonwebtoken": "^9.0.10",
      "@types/node": "25.6.2",
      "@types/supertest": "7.2.0",
      "eslint": "10.3.0",
      "eslint-config-prettier": "10.1.8",
      "jest": "30.4.2",
      "nodemon": "3.1.14",
      "prettier": "3.8.3",
      "supertest": "7.2.2",
      "ts-jest": "29.4.9",
      "ts-node": "10.9.2",
      "typescript": "6.0.3",
      "typescript-eslint": "8.59.2"
   }
}
